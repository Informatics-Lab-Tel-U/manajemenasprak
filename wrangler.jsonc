{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "manajemenasprak",
  "main": ".open-next/worker.js",
  "keep_names": false,
  "compatibility_date": "2026-06-20",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "keep_vars": true
}